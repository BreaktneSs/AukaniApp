generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  JEFE
  VENDEDOR
}

enum OrderStatus {
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIAL_REFUND
}

enum MovementType {
  ENTRY
  EXIT
  SALE
  PURCHASE
  PURCHASE_RETURN
}

enum ProductType {
  PHYSICAL
  SERVICE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ─── USUARIOS ────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts                Shift[]
  subShifts             SubShift[]
  orders                Order[]
  movements             InventoryMovement[]
  expenses              Expense[]
  purchases             Purchase[]
  purchaseReturns       PurchaseReturn[]
  createdReservations   Reservation[] @relation("ReservationCreatedBy")
  completedReservations Reservation[] @relation("ReservationCompletedBy")
  cancelledReservations Reservation[] @relation("ReservationCancelledBy")

  @@index([email])
  @@index([role])
}

// ─── CATEGORÍAS ──────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]
}

// ─── MÉTODOS DE PAGO ─────────────────────────────────────

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  payments              OrderPayment[]
  shiftPayments         ShiftPayment[]
  dispatchPayments      DispatchPayment[]
  expenses              Expense[]
  depositReservations   Reservation[] @relation("ReservationDepositMethod")
  remainingReservations Reservation[] @relation("ReservationRemainingMethod")
  refundReservations    Reservation[] @relation("ReservationRefundMethod")
}

// ─── PRODUCTOS ───────────────────────────────────────────

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  price      Decimal     @db.Decimal(10, 2)
  cost       Decimal?    @db.Decimal(10, 2)
  type       ProductType @default(PHYSICAL)
  stock      Int         @default(0)
  minStock   Int         @default(0)
  barcode    String?     @unique
  sku        String?     @unique
  imageUrl   String?
  active     Boolean     @default(true)
  categoryId Int?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  category         Category?           @relation(fields: [categoryId], references: [id])
  orderItems       OrderItem[]
  movements        InventoryMovement[]
  dispatchItems    DispatchItem[]
  accountItems     AccountItem[]
  reservationItems ReservationItem[]
  purchaseItems       PurchaseItem[]
  purchaseReturnItems PurchaseReturnItem[]

  @@index([name])
  @@index([barcode])
  @@index([active])
  @@index([categoryId])
}

// ─── TURNOS DE CAJA ──────────────────────────────────────

model Shift {
  id           Int         @id @default(autoincrement())
  userId       Int
  deviceId     String?
  deviceIp     String?
  status       ShiftStatus @default(OPEN)
  openingCash  Decimal     @db.Decimal(10, 2)
  closingCash  Decimal?    @db.Decimal(10, 2)
  expectedCash Decimal?    @db.Decimal(10, 2)
  difference   Decimal?    @db.Decimal(10, 2)
  notes        String?
  openedAt     DateTime    @default(now())
  closedAt     DateTime?

  user                  User           @relation(fields: [userId], references: [id])
  orders                Order[]
  shiftPayments         ShiftPayment[]
  subShifts             SubShift[]
  accounts              Account[]
  expenses              Expense[]
  completedReservations Reservation[]  @relation("ReservationCompletedShift")
  cancelledReservations Reservation[]  @relation("ReservationCancelledShift")

  @@index([userId])
  @@index([status])
  @@index([openedAt])
  @@index([deviceId])
}

model ShiftPayment {
  id              Int    @id @default(autoincrement())
  shiftId         Int
  paymentMethodId Int
  total           Decimal @db.Decimal(10, 2)

  shift         Shift         @relation(fields: [shiftId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@unique([shiftId, paymentMethodId])
}

model Expense {
  id              Int      @id @default(autoincrement())
  shiftId         Int
  userId          Int
  concept         String
  amount          Decimal  @db.Decimal(10, 2)
  paymentMethodId Int
  createdAt       DateTime @default(now())

  shift         Shift         @relation(fields: [shiftId], references: [id])
  user          User          @relation(fields: [userId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([shiftId])
  @@index([createdAt])
}

// ─── VENTAS ──────────────────────────────────────────────

model Order {
  id        Int         @id @default(autoincrement())
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(COMPLETED)
  userId    Int
  shiftId   Int
  createdAt DateTime    @default(now())

  user     User         @relation(fields: [userId], references: [id])
  shift    Shift        @relation(fields: [shiftId], references: [id])
  items    OrderItem[]
  payments OrderPayment[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([shiftId])
}

model OrderItem {
  id            Int      @id @default(autoincrement())
  orderId       Int
  productId     Int
  quantity      Int
  price         Decimal  @db.Decimal(10, 2)
  originalPrice Decimal? @db.Decimal(10, 2)
  priceNote     String?
  refundedQty   Int      @default(0)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderPayment {
  id              Int     @id @default(autoincrement())
  orderId         Int
  paymentMethodId Int
  amount          Decimal @db.Decimal(10, 2)

  order         Order         @relation(fields: [orderId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

// ─── COMPRAS ─────────────────────────────────────────────

model Purchase {
  id        Int            @id @default(autoincrement())
  userId    Int
  notes     String?
  total     Decimal        @db.Decimal(10, 2)
  createdAt DateTime       @default(now())

  user    User             @relation(fields: [userId], references: [id])
  items   PurchaseItem[]
  returns PurchaseReturn[]

  @@index([userId])
  @@index([createdAt])
}

model PurchaseReturn {
  id         Int                  @id @default(autoincrement())
  purchaseId Int
  userId     Int
  notes      String?
  total      Decimal              @db.Decimal(10, 2)
  createdAt  DateTime             @default(now())

  purchase Purchase             @relation(fields: [purchaseId], references: [id])
  user     User                 @relation(fields: [userId], references: [id])
  items    PurchaseReturnItem[]

  @@index([purchaseId])
  @@index([userId])
  @@index([createdAt])
}

model PurchaseReturnItem {
  id         Int     @id @default(autoincrement())
  returnId   Int
  productId  Int
  quantity   Int
  unitCost   Decimal @db.Decimal(10, 2)

  return  PurchaseReturn @relation(fields: [returnId], references: [id])
  product Product        @relation(fields: [productId], references: [id])

  @@index([returnId])
  @@index([productId])
}

model PurchaseItem {
  id         Int     @id @default(autoincrement())
  purchaseId Int
  productId  Int
  quantity   Int
  unitCost   Decimal @db.Decimal(10, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}

// ─── MOVIMIENTOS DE INVENTARIO ───────────────────────────

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  userId    Int
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

// ─── CAJAS SUBORDINADAS (meseros) ────────────────────────

enum SubShiftStatus {
  OPEN
  CLOSED
}

enum DispatchStatus {
  PENDING    // Mesero envió, cajero no ha visto
  DISPATCHED // Cajero confirmó, en camino al cliente
  DELIVERED  // Entregado al cliente
  CANCELLED  // Cancelado
}

enum AccountStatus {
  OPEN
  CLOSED
}

model SubShift {
  id          Int            @id @default(autoincrement())
  userId      Int            // Mesero
  parentShiftId Int          // Caja principal a la que está vinculado
  status      SubShiftStatus @default(OPEN)
  openedAt    DateTime       @default(now())
  closedAt    DateTime?

  user        User           @relation(fields: [userId], references: [id])
  parentShift Shift          @relation(fields: [parentShiftId], references: [id])
  dispatches  DispatchOrder[]

  @@index([userId])
  @@index([parentShiftId])
  @@index([status])
}

model DispatchOrder {
  id           Int            @id @default(autoincrement())
  subShiftId   Int
  cashReceived Decimal        @db.Decimal(10, 2)  // Total entregado por el cliente (puede ser mixto)
  change       Decimal        @db.Decimal(10, 2)  // Vuelto que el cajero debe dar
  total        Decimal        @db.Decimal(10, 2)  // Total de la venta
  status       DispatchStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())
  dispatchedAt DateTime?
  deliveredAt  DateTime?

  accountId    Int?
  account      Account?       @relation(fields: [accountId], references: [id])

  subShift  SubShift              @relation(fields: [subShiftId], references: [id])
  items     DispatchItem[]
  payments  DispatchPayment[]

  @@index([subShiftId])
  @@index([status])
  @@index([createdAt])
}

model DispatchPayment {
  id               Int     @id @default(autoincrement())
  dispatchOrderId  Int
  paymentMethodId  Int
  amount           Decimal @db.Decimal(10, 2)

  dispatchOrder  DispatchOrder  @relation(fields: [dispatchOrderId], references: [id])
  paymentMethod  PaymentMethod  @relation(fields: [paymentMethodId], references: [id])

  @@index([dispatchOrderId])
}

model DispatchItem {
  id              Int    @id @default(autoincrement())
  dispatchOrderId Int
  productId       Int
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  dispatchOrder DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([dispatchOrderId])
}

// ─── CUENTAS ABIERTAS ────────────────────────────────────

model Account {
  id        Int           @id @default(autoincrement())
  shiftId   Int
  name      String
  status    AccountStatus @default(OPEN)
  createdAt DateTime      @default(now())
  closedAt  DateTime?

  shift     Shift          @relation(fields: [shiftId], references: [id])
  items     AccountItem[]
  dispatches DispatchOrder[]

  @@index([shiftId])
  @@index([status])
}

model AccountItem {
  id        Int      @id @default(autoincrement())
  accountId Int
  productId Int
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  addedAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([accountId])
}

// ─── RESERVAS ────────────────────────────────────────────

enum ReservationStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Reservation {
  id                Int               @id @default(autoincrement())
  clientName        String
  clientPhone       String?
  notes             String?
  scheduledAt       DateTime
  totalAmount       Decimal           @db.Decimal(10, 2)
  depositAmount     Decimal           @db.Decimal(10, 2)
  depositMethodId   Int
  status            ReservationStatus @default(PENDING)
  createdByUserId   Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Al completar
  completedAt        DateTime?
  completedShiftId   Int?
  remainingAmount    Decimal?          @db.Decimal(10, 2)
  remainingMethodId  Int?
  completedByUserId  Int?

  // Al cancelar
  cancelledAt        DateTime?
  cancelledShiftId   Int?
  refundPct          Int?
  refundAmount       Decimal?          @db.Decimal(10, 2)
  refundMethodId     Int?
  cancelledByUserId  Int?

  createdBy       User           @relation("ReservationCreatedBy",    fields: [createdByUserId],  references: [id])
  completedBy     User?          @relation("ReservationCompletedBy",  fields: [completedByUserId], references: [id])
  cancelledBy     User?          @relation("ReservationCancelledBy",  fields: [cancelledByUserId], references: [id])
  depositMethod   PaymentMethod  @relation("ReservationDepositMethod",  fields: [depositMethodId],  references: [id])
  remainingMethod PaymentMethod? @relation("ReservationRemainingMethod", fields: [remainingMethodId], references: [id])
  refundMethod    PaymentMethod? @relation("ReservationRefundMethod",  fields: [refundMethodId],   references: [id])
  completedShift  Shift?         @relation("ReservationCompletedShift", fields: [completedShiftId], references: [id])
  cancelledShift  Shift?         @relation("ReservationCancelledShift", fields: [cancelledShiftId], references: [id])
  items           ReservationItem[]

  @@index([status])
  @@index([scheduledAt])
  @@index([createdByUserId])
  @@index([completedShiftId])
}

model ReservationItem {
  id            Int     @id @default(autoincrement())
  reservationId Int
  productId     Int
  quantity      Int
  price         Decimal @db.Decimal(10, 2)

  reservation Reservation @relation(fields: [reservationId], references: [id])
  product     Product     @relation(fields: [productId],     references: [id])

  @@index([reservationId])
}

// ─── AUDITORÍA ───────────────────────────────────────────

enum AuditAction {
  LOGIN
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  USER_PASSWORD_CHANGE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
  SALE_CREATE
  SALE_CANCEL
  SALE_REFUND
  SHIFT_OPEN
  SHIFT_CLOSE
  SUBSHIFT_OPEN
  SUBSHIFT_CLOSE
  DISPATCH_CREATE
  DISPATCH_CONFIRM
  DISPATCH_CANCEL
  INVENTORY_ENTRY
  INVENTORY_EXIT
  PURCHASE_CREATE
  PURCHASE_RETURN_CREATE
  ACCOUNT_CREATE
  ACCOUNT_CLOSE
  ACCOUNT_ADD_ITEMS
  ACCOUNT_ITEM_REMOVE
  EXPENSE_CREATE
  EXPENSE_DELETE
  RESERVATION_CREATE
  RESERVATION_COMPLETE
  RESERVATION_CANCEL
}

enum AuditEntity {
  AUTH
  USER
  PRODUCT
  ORDER
  SHIFT
  SUBSHIFT
  DISPATCH
  INVENTORY
  PURCHASE
  PURCHASE_RETURN
  ACCOUNT
  EXPENSE
  RESERVATION
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  userName    String
  userRole    String
  action      AuditAction
  entity      AuditEntity
  entityId    Int?
  entityLabel String?
  oldValues   Json?
  newValues   Json?
  ip          String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
