generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum Role {
  ADMIN
  JEFE
  VENDEDOR
}

enum OrderStatus {
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIAL_REFUND
}

enum MovementType {
  ENTRY
  EXIT
  SALE
}

enum ProductType {
  PHYSICAL
  SERVICE
}

enum ShiftStatus {
  OPEN
  CLOSED
}

// ─── USUARIOS ────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(VENDEDOR)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shifts     Shift[]
  subShifts  SubShift[]
  orders     Order[]
  movements  InventoryMovement[]

  @@index([email])
  @@index([role])
}

// ─── CATEGORÍAS ──────────────────────────────────────────

model Category {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  products Product[]
}

// ─── MÉTODOS DE PAGO ─────────────────────────────────────

model PaymentMethod {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  payments         OrderPayment[]
  shiftPayments    ShiftPayment[]
  dispatchPayments DispatchPayment[]
}

// ─── PRODUCTOS ───────────────────────────────────────────

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  price      Decimal     @db.Decimal(10, 2)
  cost       Decimal?    @db.Decimal(10, 2)
  type       ProductType @default(PHYSICAL)
  stock      Int         @default(0)
  minStock   Int         @default(0)
  barcode    String?     @unique
  sku        String?     @unique
  imageUrl   String?
  active     Boolean     @default(true)
  categoryId Int?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  category      Category?           @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  movements     InventoryMovement[]
  dispatchItems DispatchItem[]

  @@index([name])
  @@index([barcode])
  @@index([active])
  @@index([categoryId])
}

// ─── TURNOS DE CAJA ──────────────────────────────────────

model Shift {
  id           Int         @id @default(autoincrement())
  userId       Int
  status       ShiftStatus @default(OPEN)
  openingCash  Decimal     @db.Decimal(10, 2)
  closingCash  Decimal?    @db.Decimal(10, 2)
  expectedCash Decimal?    @db.Decimal(10, 2)
  difference   Decimal?    @db.Decimal(10, 2)
  notes        String?
  openedAt     DateTime    @default(now())
  closedAt     DateTime?

  user          User           @relation(fields: [userId], references: [id])
  orders        Order[]
  shiftPayments ShiftPayment[]
  subShifts     SubShift[]

  @@index([userId])
  @@index([status])
  @@index([openedAt])
}

model ShiftPayment {
  id              Int    @id @default(autoincrement())
  shiftId         Int
  paymentMethodId Int
  total           Decimal @db.Decimal(10, 2)

  shift         Shift         @relation(fields: [shiftId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@unique([shiftId, paymentMethodId])
}

// ─── VENTAS ──────────────────────────────────────────────

model Order {
  id        Int         @id @default(autoincrement())
  total     Decimal     @db.Decimal(10, 2)
  status    OrderStatus @default(COMPLETED)
  userId    Int
  shiftId   Int
  createdAt DateTime    @default(now())

  user     User         @relation(fields: [userId], references: [id])
  shift    Shift        @relation(fields: [shiftId], references: [id])
  items    OrderItem[]
  payments OrderPayment[]

  @@index([createdAt])
  @@index([status])
  @@index([userId])
  @@index([shiftId])
}

model OrderItem {
  id           Int     @id @default(autoincrement())
  orderId      Int
  productId    Int
  quantity     Int
  price        Decimal @db.Decimal(10, 2)
  refundedQty  Int     @default(0)

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model OrderPayment {
  id              Int     @id @default(autoincrement())
  orderId         Int
  paymentMethodId Int
  amount          Decimal @db.Decimal(10, 2)

  order         Order         @relation(fields: [orderId], references: [id])
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])
}

// ─── MOVIMIENTOS DE INVENTARIO ───────────────────────────

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  userId    Int
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

// ─── CAJAS SUBORDINADAS (meseros) ────────────────────────

enum SubShiftStatus {
  OPEN
  CLOSED
}

enum DispatchStatus {
  PENDING    // Mesero envió, cajero no ha visto
  DISPATCHED // Cajero confirmó despacho
  CANCELLED  // Cancelado
}

model SubShift {
  id          Int            @id @default(autoincrement())
  userId      Int            // Mesero
  parentShiftId Int          // Caja principal a la que está vinculado
  status      SubShiftStatus @default(OPEN)
  openedAt    DateTime       @default(now())
  closedAt    DateTime?

  user        User           @relation(fields: [userId], references: [id])
  parentShift Shift          @relation(fields: [parentShiftId], references: [id])
  dispatches  DispatchOrder[]

  @@index([userId])
  @@index([parentShiftId])
  @@index([status])
}

model DispatchOrder {
  id           Int            @id @default(autoincrement())
  subShiftId   Int
  cashReceived Decimal        @db.Decimal(10, 2)  // Total entregado por el cliente (puede ser mixto)
  change       Decimal        @db.Decimal(10, 2)  // Vuelto que el cajero debe dar
  total        Decimal        @db.Decimal(10, 2)  // Total de la venta
  status       DispatchStatus @default(PENDING)
  notes        String?
  createdAt    DateTime       @default(now())
  dispatchedAt DateTime?

  subShift  SubShift              @relation(fields: [subShiftId], references: [id])
  items     DispatchItem[]
  payments  DispatchPayment[]

  @@index([subShiftId])
  @@index([status])
  @@index([createdAt])
}

model DispatchPayment {
  id               Int     @id @default(autoincrement())
  dispatchOrderId  Int
  paymentMethodId  Int
  amount           Decimal @db.Decimal(10, 2)

  dispatchOrder  DispatchOrder  @relation(fields: [dispatchOrderId], references: [id])
  paymentMethod  PaymentMethod  @relation(fields: [paymentMethodId], references: [id])

  @@index([dispatchOrderId])
}

model DispatchItem {
  id              Int    @id @default(autoincrement())
  dispatchOrderId Int
  productId       Int
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  dispatchOrder DispatchOrder @relation(fields: [dispatchOrderId], references: [id])
  product       Product       @relation(fields: [productId], references: [id])

  @@index([dispatchOrderId])
}

// ─── AUDITORÍA ───────────────────────────────────────────

enum AuditAction {
  LOGIN
  USER_CREATE
  USER_UPDATE
  USER_DEACTIVATE
  USER_PASSWORD_CHANGE
  PRODUCT_CREATE
  PRODUCT_UPDATE
  PRODUCT_DELETE
  SALE_CREATE
  SALE_CANCEL
  SALE_REFUND
  SHIFT_OPEN
  SHIFT_CLOSE
  SUBSHIFT_OPEN
  SUBSHIFT_CLOSE
  DISPATCH_CREATE
  DISPATCH_CONFIRM
  DISPATCH_CANCEL
  INVENTORY_ENTRY
  INVENTORY_EXIT
}

enum AuditEntity {
  AUTH
  USER
  PRODUCT
  ORDER
  SHIFT
  SUBSHIFT
  DISPATCH
  INVENTORY
}

model AuditLog {
  id          Int         @id @default(autoincrement())
  userId      Int?
  userName    String
  userRole    String
  action      AuditAction
  entity      AuditEntity
  entityId    Int?
  entityLabel String?
  oldValues   Json?
  newValues   Json?
  ip          String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}
