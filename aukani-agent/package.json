{
  "name": "aukani-agent",
  "version": "1.0.0",
  "description": "Agente local Aukani POS - Control de impresora y cajón de efectivo",
  "main": "src/agent.js",
  "bin": "src/agent.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/agent.js",
    "dev": "nodemon src/agent.js",
    "build:win": "pkg . --target node20-win-x64 --output dist/aukani-agent-windows.exe",
    "build:linux": "pkg . --target node20-linux-x64 --output dist/aukani-agent-linux",
    "build:mac": "pkg . --target node20-macos-x64 --output dist/aukani-agent-mac",
    "build:all": "pkg . --targets node20-win-x64,node20-linux-x64 --out-path dist/"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "@yao-pkg/pkg": "^5.12.0"
  },
  "pkg": {
    "assets": [
      "src/**/*"
    ],
    "targets": [
      "node20-win-x64",
      "node20-linux-x64"
    ],
    "outputPath": "dist"
  }
}
